# Copy this file to `.env` and paste your Supabase project values.
# Find them in Supabase: Project Settings → API.
# The anon key is safe to expose in a browser app — do NOT use the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
